# Copy to .env.local and fill in real values.

# Neon Postgres connection string (pooled, sslmode=require).
# Get it from the Neon dashboard or `psql` connection details.
DATABASE_URL=postgres://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# Static API key the Embroidery System sends as the `x-api-key` header
# to the read-only export route (/api/export/orders). Use a long random string.
EXPORT_API_KEY=replace-with-a-long-random-string

# Auth.js v5 secret — used to sign/encrypt session JWTs.
# Generate one with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=replace-with-a-long-random-string

# App version surfaced in the UI footer and /api/health.
NEXT_PUBLIC_APP_VERSION=1.0.0
